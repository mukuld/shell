#!/bin/bash

# --- CONFIGURATION ---
# Colors for better readability
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# --- HELP FUNCTION ---
function show_help {
    echo -e "${YELLOW}Usage:${NC} ./gsync.sh \"Your commit message\""
    echo -e "Example: ./gsync.sh \"Refactored the login logic\""
    exit 1
}

# 1. Check if help is requested or message is missing
if [[ "$1" == "-h" ]] || [[ "$1" == "--help" ]] || [[ -z "$1" ]]; then
    show_help
fi

# 2. Capture the full message (handles quoted strings correctly)
msg="$*"

# 3. Safety Check: Which branch are we on?
current_branch=$(git rev-parse --abbrev-ref HEAD)

echo -e "${YELLOW}Pushing to branch:${NC} $current_branch"

# Optional: Add a 'Main' branch protector
if [ "$current_branch" == "main" ] || [ "$current_branch" == "master" ]; then
    read -p "⚠️  You are on $current_branch. Are you sure you want to push? (y/n) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo -e "${RED}Push aborted.${NC}"
        exit 1
    fi
fi

# 4. The Execution
echo -e "${GREEN}Adding files...${NC}"
git add .

echo -e "${GREEN}Committing: ${NC}\"$msg\""
if git commit -m "$msg"; then
    echo -e "${GREEN}Pushing to origin...${NC}"
    if git push; then
        echo -e "${GREEN}✅ Success! Workflow complete.${NC}"
    else
        echo -e "${RED}❌ Error: Push failed. Check your connection or remote status.${NC}"
    fi
else
    echo -e "${RED}❌ Error: Commit failed. Are there any changes to commit?${NC}"
fi
